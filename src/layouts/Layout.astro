---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Shlomo Hecht",
  description = "Professional keyboardist available for weddings, corporate events, and private performances."
} = Astro.props;
const isHome = Astro.url.pathname === "/";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=7" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Domine:wght@400;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:       #0a0a0a;
      --surface:  #111111;
      --border:   #1e1e1e;
      --text:     #f0ede8;
      --muted:    #666;
      --gold:     #c8a96e;
      --gold-dim: rgba(200, 169, 110, 0.1);
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', sans-serif;
      font-weight: 300;
      line-height: 1.75;
      min-height: 100vh;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
    }

    h1, h2, h3, h4 {
      font-family: 'Domine', serif;
      font-weight: 700;
      letter-spacing: 0.03em;
      line-height: 1.15;
    }

    a { color: inherit; text-decoration: none; }

    .container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 1.25rem;
    }
    @media (min-width: 640px) {
      .container { padding: 0 2rem; }
    }

    .btn-gold {
      display: inline-block;
      padding: 0.85rem 2.5rem;
      border: 1px solid var(--gold);
      color: var(--gold);
      background: transparent;
      font-family: 'Inter', sans-serif;
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      transition: background 0.25s, color 0.25s;
      cursor: pointer;
    }
    .btn-gold:hover {
      background: var(--gold);
      color: var(--bg);
    }

    section { padding: 3.5rem 0; }
    @media (min-width: 720px) {
      section { padding: 6rem 0; }
    }

    .section-label {
      font-size: 0.68rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1rem;
    }

    .divider {
      width: 40px;
      height: 1px;
      background: var(--gold);
      margin: 1.5rem 0;
    }

    p { color: rgba(240, 237, 232, 0.68); }

    strong { color: var(--text); font-weight: 500; }
  </style>
</head>
<body>

  <nav id="site-nav">
    <div class="nav-inner container">
      {isHome && (
        <a href="/" class="nav-logo">
          <img src="/shp-logo.svg" alt="SHP" />
        </a>
      )}
      <button class="nav-toggle" aria-label="Menu" aria-expanded="false" aria-controls="nav-menu">
        <span></span><span></span><span></span>
      </button>
      <ul class="nav-links" id="nav-menu">
        <li><a href="/">Home</a></li>
        <li><a href="/bio">Bio</a></li>
        <li><a href="/book" class="nav-book">Book Now</a></li>
      </ul>
    </div>
  </nav>

  <slot />

  <footer>
    <div class="container footer-inner">
      <span class="footer-copy">&copy; {new Date().getFullYear()} All rights reserved.</span>
      <div class="footer-socials">
        <a href="https://www.instagram.com/shlomo_hecht_productions/" aria-label="Instagram" class="social-link" target="_blank" rel="noopener">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>
        <a href="https://www.youtube.com/@ShlomoHechtProductions" aria-label="YouTube" class="social-link" target="_blank" rel="noopener">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/>
            <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/>
          </svg>
        </a>
      </div>
    </div>
  </footer>

</body>
</html>

<style>
  #site-nav {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    z-index: 100;
    padding: 0;
    background: transparent;
    border-bottom: none;
  }

  .nav-inner {
    display: block;
    position: relative;
    min-height: clamp(140px, 32dvh, 310px);
    padding-top: env(safe-area-inset-top);
  }

  .nav-logo {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
  }

  .nav-logo img {
    height: 110px;
    width: auto;
    display: block;
  }

  /* Hamburger — fixed to top-right on mobile so it's always tappable */
  .nav-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 32px;
    height: 32px;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    position: fixed;
    top: calc(1.25rem + env(safe-area-inset-top));
    right: 1.25rem;
    z-index: 102;
  }
  .nav-toggle span {
    display: block;
    width: 24px;
    height: 1.5px;
    background: var(--text);
    transition: transform 0.3s ease, opacity 0.2s ease;
  }
  .nav-toggle[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .nav-toggle[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* Nav menu — slide-in panel on mobile */
  .nav-links {
    list-style: none;
    position: fixed;
    top: 0;
    right: 0;
    width: max-content;
    min-width: 180px;
    max-width: 72vw;
    height: 100vh;
    height: 100dvh;
    background: rgba(10, 10, 10, 0.98);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-left: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding: 5.5rem 1.75rem 2rem;
    transform: translateX(100%);
    transition: transform 0.35s ease;
    z-index: 101;
  }
  .nav-links.open {
    transform: translateX(0);
  }
  .nav-links a {
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text);
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--gold); }

  .nav-book {
    display: inline-block;
    color: var(--gold) !important;
    border: 1px solid rgba(200, 169, 110, 0.5);
    padding: 0.75rem 1.4rem;
    text-align: center;
    transition: background 0.2s, color 0.2s, border-color 0.2s !important;
  }
  .nav-book:hover {
    background: var(--gold);
    color: var(--bg) !important;
    border-color: var(--gold) !important;
  }

  /* Desktop — horizontal nav, no hamburger */
  @media (min-width: 720px) {
    #site-nav {
      position: fixed;
      padding: 1.1rem 0;
      background: rgba(10, 10, 10, 0.88);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--border);
    }

    .nav-inner {
      display: flex;
      justify-content: space-between;
      align-items: center;
      min-height: 0;
      padding-top: 0;
    }

    .nav-logo {
      position: static;
      transform: none;
    }
    .nav-logo img { height: 34px; }

    .nav-toggle { display: none; }

    .nav-links {
      position: static;
      width: auto;
      height: auto;
      background: transparent;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      border-left: none;
      flex-direction: row;
      align-items: center;
      gap: 2.5rem;
      padding: 0;
      transform: none;
      transition: none;
    }
    .nav-links a {
      font-size: 0.72rem;
      letter-spacing: 0.16em;
      text-shadow: 0 1px 6px rgba(0, 0, 0, 0.8);
    }
    .nav-book {
      padding: 0.5rem 1.3rem;
    }
  }

  footer {
    border-top: 1px solid var(--border);
    padding: 2.5rem 0;
    margin-top: auto;
  }
  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-align: center;
    align-items: center;
  }
  .footer-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    letter-spacing: 0.06em;
    color: var(--text);
  }
  .footer-copy {
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--muted);
  }

  .footer-socials {
    display: flex;
    gap: 1.25rem;
    align-items: center;
  }

  .social-link {
    color: var(--muted);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s ease;
  }

  .social-link:hover,
  .social-link:focus-visible {
    color: var(--gold);
  }

  @media (min-width: 640px) {
    .footer-inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const menu = document.querySelector<HTMLUListElement>('.nav-links');
  if (toggle && menu) {
    const setOpen = (open: boolean) => {
      menu.classList.toggle('open', open);
      toggle.setAttribute('aria-expanded', String(open));
      document.body.style.overflow = open ? 'hidden' : '';
    };
    toggle.addEventListener('click', () => {
      setOpen(!menu.classList.contains('open'));
    });
    menu.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => setOpen(false));
    });
    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu.classList.contains('open')) setOpen(false);
    });
  }
</script>
