---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Bio — Shlomo Hecht">

  <section class="page-hero">
    <div class="container">
      <p class="section-label">The Musician</p>
      <h1>About Shlomo</h1>
      <div class="divider"></div>
      <div class="hero-photo-row">
        <div class="hero-photo-wrap">
          <img src="/keyboardist.jpg" alt="Shlomo Hecht" class="hero-photo" />
        </div>
        <aside class="bio-aside">
          <div class="aside-card">
            <p class="aside-label">Experience</p>
            <p class="aside-val">5+ Years</p>
          </div>
          <div class="aside-card">
            <p class="aside-label">Events Performed</p>
            <p class="aside-val">100+</p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="bio-section">
    <div class="container">
      <div class="bio-body">
        <p>
          Shlomo Hecht is a professional musician with years of experience, performing at simchas
          and events nationwide. More recently at the age of 20, he has brought his talents to the
          Tri-State area, quickly making a name for himself in the local music scene. Known for his
          dynamic energy, precision, and warmth, Shlomo elevates every event he plays. Whether it's
          an elegant wedding reception, a high-energy Bar Mitzvah, or a sophisticated corporate gala,
          he adapts seamlessly to the atmosphere—delivering performances that feel both tailored and unforgettable.
        </p>
        <p style="margin-top:1.5rem">
          Equipped with a full professional keyboard rig, Shlomo adapts seamlessly to any
          venue or event type — from elegant wedding receptions to high-energy corporate galas.
        </p>
        <div class="bio-cta"><a href="/book" class="btn-gold">Check Availability</a></div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-hero {
    padding: 6.5rem 0 0;
  }
  .page-hero h1 {
    font-size: clamp(2.25rem, 6vw, 5rem);
    color: var(--text);
  }
  @media (min-width: 720px) {
    .page-hero { padding: 10rem 0 0; }
  }

  .hero-photo-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    margin-top: 2rem;
  }

  .hero-photo-wrap {
    width: min(260px, 70vw);
    aspect-ratio: 1 / 1;
    border: 3px solid var(--gold);
    box-shadow: 0 0 0 6px rgba(200,169,110,0.15);
    overflow: hidden;
    flex-shrink: 0;
  }

  .hero-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  @media (min-width: 720px) {
    .hero-photo-row {
      flex-direction: row;
      align-items: center;
      gap: 3rem;
      margin-top: 2.5rem;
    }
    .hero-photo-wrap {
      width: 260px;
      height: 260px;
    }
  }

  .bio-section { padding-top: 2.5rem; }

  .bio-cta {
    margin-top: 3rem;
    text-align: center;
  }

.bio-body p { font-size: 1rem; line-height: 1.85; }

  .bio-body h3 {
    font-size: 1.25rem;
    color: var(--text);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .bio-body ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .bio-body ul li {
    font-size: 0.9rem;
    color: rgba(240,237,232,0.65);
    padding-left: 1.2rem;
    position: relative;
  }
  .bio-body ul li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--gold);
    font-size: 0.75rem;
  }

  .bio-aside {
    display: flex;
    flex-direction: row;
    gap: 0;
    border: 1px solid var(--border);
    width: 100%;
  }

  .aside-card {
    padding: 1.25rem;
    border-right: 1px solid var(--border);
    flex: 1;
    text-align: center;
  }
  .aside-card:last-child { border-right: none; }

  .aside-label {
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.4rem;
  }
  .aside-val {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.15rem;
    color: var(--text) !important;
    line-height: 1.4;
  }

  @media (min-width: 720px) {
    .bio-aside {
      flex-direction: column;
      width: auto;
    }
    .aside-card {
      padding: 1.5rem;
      border-right: none;
      border-bottom: 1px solid var(--border);
      text-align: left;
      flex: 0 0 auto;
    }
    .aside-card:last-child { border-bottom: none; }
    .aside-label {
      font-size: 0.68rem;
      letter-spacing: 0.2em;
    }
    .aside-val { font-size: 1.2rem; }
  }
</style>
