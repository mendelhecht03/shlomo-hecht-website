---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Bio — Shlomo Hecht">

  <section class="page-hero">
    <div class="container">
      <p class="section-label">The Artist</p>
      <h1>About Shlomo</h1>
      <div class="divider"></div>
    </div>
  </section>

  <section class="bio-section">
    <div class="container bio-grid">
      <div class="bio-body">
        <p>
          Shlomo Hecht is a professional musician with extensive experience performing
          at premier events across the country. Specializing in jazz, classical, and
          contemporary styles, he brings energy, precision, and warmth to every performance.
        </p>
        <p style="margin-top:1.5rem">
          Equipped with a full professional keyboard rig, Shlomo adapts seamlessly to any
          venue or event type — from elegant wedding receptions to high-energy corporate galas.
        </p>

        <h3>What to expect</h3>
        <ul>
          <li>Tailored setlists built around your event</li>
          <li>Professional equipment — no venue logistics to worry about</li>
          <li>Jazz, classical, pop, and contemporary repertoire</li>
          <li>Punctual, professional, and easy to work with</li>
        </ul>

        <h3>Event types</h3>
        <ul>
          <li>Weddings &amp; receptions</li>
          <li>Corporate events &amp; galas</li>
          <li>Private parties &amp; celebrations</li>
          <li>Fundraisers &amp; charity events</li>
        </ul>

        <a href="/book" class="btn-gold" style="margin-top:3rem">Check Availability</a>
      </div>

      <aside class="bio-aside">
        <div class="aside-card">
          <p class="aside-label">Experience</p>
          <p class="aside-val">10+ Years</p>
        </div>
        <div class="aside-card">
          <p class="aside-label">Events Performed</p>
          <p class="aside-val">200+</p>
        </div>
        <div class="aside-card">
          <p class="aside-label">Specialties</p>
          <p class="aside-val">Jazz · Classical · Contemporary</p>
        </div>
        <div class="aside-card">
          <p class="aside-label">Equipment</p>
          <p class="aside-val">Full professional rig included</p>
        </div>
      </aside>
    </div>
  </section>

</Layout>

<style>
  .page-hero {
    padding: 10rem 0 3rem;
  }
  .page-hero h1 {
    font-size: clamp(3rem, 6vw, 5rem);
    color: var(--text);
  }

  .bio-section { padding-top: 2rem; }

  .bio-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 5rem;
    align-items: start;
  }

  .bio-body p { font-size: 1rem; line-height: 1.85; }

  .bio-body h3 {
    font-size: 1.25rem;
    color: var(--text);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .bio-body ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .bio-body ul li {
    font-size: 0.9rem;
    color: rgba(240,237,232,0.65);
    padding-left: 1.2rem;
    position: relative;
  }
  .bio-body ul li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--gold);
    font-size: 0.75rem;
  }

  .bio-aside {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--border);
  }

  .aside-card {
    padding: 1.5rem;
    border-bottom: 1px solid var(--border);
  }
  .aside-card:last-child { border-bottom: none; }

  .aside-label {
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.4rem;
  }
  .aside-val {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem;
    color: var(--text) !important;
    line-height: 1.4;
  }

  @media (max-width: 820px) {
    .bio-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .bio-aside { order: -1; }
  }
</style>
