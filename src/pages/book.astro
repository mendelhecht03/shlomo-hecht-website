---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Book Shlomo Hecht — Check Availability">

  <section class="page-hero">
    <div class="container">
      <p class="section-label">Availability</p>
      <h1>Book a Performance</h1>
      <div class="divider"></div>
      <p class="page-sub">
        Select a date and time below. The calendar is synced with Shlomo's live availability —
        only open slots are bookable.
      </p>
    </div>
  </section>

  <section class="cal-section">
    <div class="container">
      <iframe
        src="https://cal.com/shlomo-hecht-wr8f3t/book-shlomo-for-an-event?theme=dark"
        width="100%"
        height="900"
        frameborder="0"
        scrolling="no"
      ></iframe>
    </div>
  </section>

</Layout>

<style>
  .page-hero {
    padding: 10rem 0 4rem;
    text-align: center;
  }
  .page-hero h1 {
    font-size: clamp(2.8rem, 6vw, 5rem);
    color: var(--text);
  }
  .divider { margin: 1.5rem auto; }
  .page-sub {
    max-width: 500px;
    margin: 0 auto;
    font-size: 0.92rem;
  }

  .cal-section {
    padding-top: 1rem;
    padding-bottom: 6rem;
  }

  iframe {
    display: block;
    border: 1px solid var(--border);
    border-radius: 2px;
    overflow: hidden;
  }
</style>

