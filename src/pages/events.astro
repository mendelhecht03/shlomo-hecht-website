---
import Layout from '../layouts/Layout.astro';

const events = [
  {
    name: "Smith Wedding Reception",
    date: "June 15, 2024",
    location: "The Grand Hotel",
    type: "Wedding",
    description: "Jazz and classical mix for an evening reception of 200 guests."
  },
  {
    name: "Corporate Gala",
    date: "May 20, 2024",
    location: "Downtown Marriott",
    type: "Corporate",
    description: "Ambient and contemporary background music for a tech company gala."
  },
  {
    name: "Jazz Night Fundraiser",
    date: "April 10, 2024",
    location: "Local Community Center",
    type: "Charity",
    description: "Featured performer for a sold-out charity fundraiser event."
  }
];
---
<Layout title="Events — Shlomo Hecht">

  <section class="page-hero">
    <div class="container">
      <p class="section-label">Portfolio</p>
      <h1>Past Events</h1>
      <div class="divider"></div>
      <p class="page-sub">A selection of performances and events.</p>
    </div>
  </section>

  <section class="events-section">
    <div class="container">
      <div class="events-list">
        {events.map((event, i) => (
          <article class="event-row">
            <span class="event-index">{String(i + 1).padStart(2, '0')}</span>
            <div class="event-main">
              <h3>{event.name}</h3>
              <p>{event.description}</p>
            </div>
            <div class="event-meta">
              <span class="event-type">{event.type}</span>
              <span class="event-date">{event.date}</span>
              <span class="event-location">{event.location}</span>
            </div>
          </article>
        ))}
      </div>

      <div class="events-cta">
        <p>Want to be next on this list?</p>
        <a href="/book" class="btn-gold">Book Now</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-hero {
    padding: 10rem 0 3rem;
  }
  .page-hero h1 {
    font-size: clamp(3rem, 6vw, 5rem);
    color: var(--text);
  }
  .page-sub { font-size: 0.9rem; }

  .events-section { padding-top: 2rem; }

  .events-list {
    border-top: 1px solid var(--border);
  }

  .event-row {
    display: grid;
    grid-template-columns: 3rem 1fr auto;
    gap: 2.5rem;
    align-items: center;
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--border);
    transition: background 0.2s;
  }
  .event-row:hover {
    background: var(--gold-dim);
    padding-left: 1rem;
    padding-right: 1rem;
    margin: 0 -1rem;
    border-radius: 2px;
  }

  .event-index {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem;
    color: var(--gold);
    opacity: 0.6;
  }

  .event-main h3 {
    font-size: 1.4rem;
    color: var(--text);
    margin-bottom: 0.4rem;
  }
  .event-main p { font-size: 0.88rem; }

  .event-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.4rem;
    text-align: right;
  }

  .event-type {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    border: 1px solid rgba(200,169,110,0.3);
    padding: 0.25rem 0.6rem;
    border-radius: 1px;
  }

  .event-date,
  .event-location {
    font-size: 0.78rem;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .events-cta {
    margin-top: 5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
  }
  .events-cta p {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    color: var(--text);
    font-style: italic;
  }

  @media (max-width: 700px) {
    .event-row {
      grid-template-columns: 2.5rem 1fr;
      grid-template-rows: auto auto;
    }
    .event-meta {
      grid-column: 2;
      align-items: flex-start;
      text-align: left;
    }
  }
</style>
