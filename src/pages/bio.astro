---
const pageTitle = "Bio";
---

<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{pageTitle}</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      max-width: 900px;
      margin: 0 auto;
      padding: 20px;
      line-height: 1.6;
      color: #333;
    }
    
    header {
      border-bottom: 2px solid #333;
      padding-bottom: 20px;
      margin-bottom: 40px;
    }
    
    h1 {
      margin: 0;
      font-size: 2.5em;
    }
    
    nav {
      margin-top: 20px;
    }
    
    nav a {
      margin-right: 20px;
      text-decoration: none;
      color: #0066cc;
      font-weight: bold;
    }
    
    nav a:hover {
      text-decoration: underline;
    }
    
    main {
      max-width: 700px;
    }
  </style>
</head>
<body>
  <header>
    <h1>Alex Keyboards</h1>
    <p>Professional Keyboardist | Events & Bookings</p>
    <nav>
      <a href="/">Home</a>
      <a href="/bio">Bio</a>
      <a href="/events">Past Events</a>
      <a href="/contact">Contact</a>
    </nav>
  </header>

  <main>
    <h2>About Me</h2>
    <p>
      I'm a professional keyboardist with 10+ years of experience performing at weddings, corporate events, and private functions.
    </p>
    <p>
      Specializing in jazz, classical, and contemporary styles, I bring energy and professionalism to every performance.
    </p>
    <p>
      I'm equipped with a full keyboard rig and can adapt to any venue or event type.
    </p>
    <h3>Experience</h3>
    <ul>
      <li>100+ events performed</li>
      <li>Weddings, corporate events, private parties</li>
      <li>Full technical setup included</li>
    </ul>
  </main>

  <footer>
    <p>&copy; 2026. All rights reserved.</p>
  </footer>
</body>
</html>